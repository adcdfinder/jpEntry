{
  "name": "jp-entry",
  "version": "1.0.4",
  "description": "Electron Kiosk Application",
  "author": {
    "name": "adcdfinder",
    "email": "adcdfinder@example.com"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "build": "electron-builder --win",
    "dist:appimage": "electron-builder --linux AppImage"
  },
  "dependencies": {
    "otplib": "^12.0.1"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.opengeolabs.jpentry",
    "productName": "JP Entry",
    "icon": "icon.png",
    "files": [
      "main.js",
      "preload.js",
      "credential-store.js",
      "instance-profile.js",
      "navigation-history.js",
      "otp-autofill.js",
      "*.html",
      "icon.ico"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png",
      "requestedExecutionLevel": "requireAdministrator",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "JP Entry"
    },
    "portable": {
      "artifactName": "JPEntry-portable.exe"
    }
  }
}
